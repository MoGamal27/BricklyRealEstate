        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/properties?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["properties"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Properties with Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/properties?type=VILLA&minPrice=1000000&maxPrice=3000000&bedrooms=4&city=Dubai&status=APPROVED",
              "host": ["{{baseUrl}}"],
              "path": ["properties"],
              "query": [
                {
                  "key": "type",
                  "value": "VILLA"
                },
                {
                  "key": "minPrice",
                  "value": "1000000"
                },
                {
                  "key": "maxPrice",
                  "value": "3000000"
                },
                {
                  "key": "bedrooms",
                  "value": "4"
                },
                {
                  "key": "city",
                  "value": "Dubai"
                },
                {
                  "key": "status",
                  "value": "APPROVED"
                }
              ]
            }
          }
        },
